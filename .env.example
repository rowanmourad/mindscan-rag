# Copy this file to .env (or just export these in your shell) and fill in your values.
# main.py reads OPENROUTER_API_KEY from the environment automatically.
# The MINDSCAN_* variables are optional -- sensible defaults are used if you skip them.

OPENROUTER_API_KEY=sk-or-your-key-here

# Optional path overrides (defaults shown are relative to the project folder):
# MINDSCAN_BASE_DIR=./data
# MINDSCAN_PDF_DIR=./data/papers
# MINDSCAN_CHROMA_DIR=./data/vector_db
# MINDSCAN_SAMPLE_IMAGES_DIR=./data/sample_images
# MINDSCAN_REPO_DIR=.
# MINDSCAN_MODELS_DIR=./models
# MINDSCAN_REPORTS_DIR=./reports
